{
  "name": "backend-code-challenge",
  "version": "1.0.0",
  "description": "Backend interview challenge organized by problem folders",
  "private": true,
  "type": "module",
  "workspaces": [
    "problems/problem5"
  ],
  "scripts": {
    "test": "npm run test:problem4 && npm run test:problem5",
    "test:problem4": "node --test --test-isolation=none problems/problem4/index.test.ts",
    "setup:problem5": "npm --prefix problems/problem5 run setup",
    "dev:problem5": "npm --prefix problems/problem5 run dev",
    "test:problem5": "npm --prefix problems/problem5 test",
    "build:problem5": "npm --prefix problems/problem5 run build",
    "start:problem5": "npm --prefix problems/problem5 start"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  }
}
