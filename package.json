{
  "name": "backend-code-challenge",
  "version": "1.0.0",
  "description": "Backend interview challenge organized by problem folders",
  "private": true,
  "type": "module",
  "workspaces": [
    "problems/problem2"
  ],
  "scripts": {
    "test": "npm run test:problem1 && npm run test:problem2",
    "test:problem1": "node --test --test-isolation=none problems/problem1/index.test.ts",
    "setup:problem2": "npm --prefix problems/problem2 run setup",
    "dev:problem2": "npm --prefix problems/problem2 run dev",
    "test:problem2": "npm --prefix problems/problem2 test",
    "build:problem2": "npm --prefix problems/problem2 run build",
    "start:problem2": "npm --prefix problems/problem2 start"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  }
}
